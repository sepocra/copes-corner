---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} mainClass="blog-list-main">
  <style is:global slot="head">
    @media (max-width: 720px) {
      main.blog-list-main {
        padding: 1.5em 1em;
      }
    }
  </style>

  <section class="observations-list">

    <h1 class="page-label">Observations</h1>

    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>
            <h4 class="title">{post.data.title}</h4>
            {post.data.description && <p class="excerpt">{post.data.description}</p>}
            <div class="meta">
              <span class="date">
                <FormattedDate date={post.data.pubDate} />
              </span>
              {post.data.tags && post.data.tags[0] && (
                <span class="tag">{post.data.tags[0]}</span>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>

  </section>
</BaseLayout>

<style>
  .observations-list {
    padding: 3rem 0 4rem;
  }

  /* ── Page heading — matches "What I notice" / "Latest" label style ── */
  .page-label {
    font-family: 'Lora', Georgia, serif;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7645;
    margin: 0 0 2rem;
  }

  /* ── Post list ── */
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-list li a {
    display: block;
    text-decoration: none;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding: 1.5rem 0;
    transition: color 0.2s ease;
  }

  .post-list li:last-child a {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .post-list li a:hover .title {
    color: #6b7645;
  }

  .title {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 400;
    margin: 0 0 0.4rem;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .excerpt {
    font-size: 0.9rem;
    margin: 0 0 0.75rem;
    line-height: 1.6;
    font-style: italic;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .date {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 300;
    font-size: 0.78rem;
    color: #888;
  }

  .tag {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 300;
    font-size: 0.72rem;
    background-color: rgba(107, 118, 69, 0.1);
    color: #6b7645;
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }

  /* ── Dark mode ── */
  @media (prefers-color-scheme: dark) {
    .post-list li a {
      border-top-color: rgba(255, 255, 255, 0.07);
    }

    .post-list li:last-child a {
      border-bottom-color: rgba(255, 255, 255, 0.07);
    }

    .date {
      color: #6a6860;
    }

    .tag {
      background-color: rgba(122, 158, 104, 0.15);
      color: #7a9e68;
    }
  }
</style>
