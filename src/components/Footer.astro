---
const linkedInUrl = "https://www.linkedin.com/in/craigcopes";
const email = "sepocra@gmail.com";
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="tagline">Written from somewhere in Australia.</p>
    <p class="contact-links">
      <a href={linkedInUrl} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href={`mailto:${email}`}>Email</a>
    </p>
  </div>
</footer>
<style>
  .site-footer {
    margin: 0;
    padding: 0;
    background: #1e1e1e;
    border-top: 2px solid #6b7645;
    color: #8a8a8a;
    text-align: center;
  }
  .footer-inner {
    width: 720px;
    max-width: calc(100% - 2em);
    margin: 0 auto;
    box-sizing: border-box;
    padding: 1.5rem 1em 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .tagline {
    margin: 0;
    font-size: 0.95rem;
    font-style: italic;
    color: #7a7a7a;
    line-height: 1.5;
    max-width: 28em;
  }
  .contact-links {
    margin: 0;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      Segoe UI,
      sans-serif;
    font-size: 0.95rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem 0.5rem;
  }
  .contact-links a {
    color: #7a9e68;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .contact-links a:hover {
    color: #96b885;
  }
  .sep {
    color: #5a5a5a;
    user-select: none;
  }
  @media (max-width: 640px) {
    .footer-inner {
      padding: 1.25rem 1em 2rem;
    }
    .contact-links {
      flex-direction: column;
      gap: 0.35rem;
    }
    .sep {
      display: none;
    }
  }
</style>
