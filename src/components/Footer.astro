---
const linkedInUrl = "https://www.linkedin.com/in/craigcopes";
const email = "sepocra@gmail.com";
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="tagline">Written from somewhere in Australia.</p>
    <p class="contact-links">
      <a href={linkedInUrl} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href={`mailto:${email}`}>Email</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin: 0;
    padding: 0;
    background: #1e1e1e;
    border-top: 2px solid #6b7645;
    color: #8a8a8a;
  }

  .footer-inner {
    width: 720px;
    max-width: calc(100% - 2em);
    margin: 0 auto;
    box-sizing: border-box;
    padding: 1.25rem 1em;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tagline {
    margin: 0;
    font-size: 0.8rem;
    font-style: italic;
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 300;
    color: #7a7a7a;
    line-height: 1.5;
  }

  .contact-links {
    margin: 0;
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 0.8rem;
    font-weight: 300;
    letter-spacing: 0.06em;
    display: flex;
    flex-direction: row;  /* always row — never stack links */
    align-items: center;
    gap: 0.35rem 0.5rem;
    flex-shrink: 0;
  }

  .contact-links a {
    color: #7a9e68;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-links a:hover {
    color: #96b885;
    text-decoration: underline;
  }

  .sep {
    color: #5a5a5a;
    user-select: none;
  }

  /* Mobile: stack tagline above links, but keep links side by side */
  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1.25rem 1em 2rem;
    }

    /* .contact-links stays flex-direction: row — links remain side by side */
    .contact-links {
      justify-content: center;
    }
  }
</style>
