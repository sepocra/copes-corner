---
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
  <div class="site-nav">
    <h2 class="site-title">
      <a class="wordmark" href="/">{SITE_TITLE}</a>
    </h2>
    <a class="obs-link" href="/blog/">
      <span class="obs-label">Observations</span>
      <span class="obs-arrow" aria-hidden="true">â†’</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    margin: 0;
    padding: 0;
    background: #1e1e1e;
    border-bottom: 2px solid #6b7645;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 860px;
    max-width: calc(100% - 2em);
    margin: 0 auto;
    box-sizing: border-box;
    padding: 0.65rem 1em;
  }

  .site-title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.2;
    font-family: 'Lora', Georgia, serif;
  }

  .wordmark,
  .wordmark:visited {
    color: #e8e0d0;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .wordmark:hover {
    color: #f5f0e6;
  }

  /* â”€â”€ Observations link â€” label style â”€â”€ */
  .obs-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
  }

  .obs-label {
    font-family: 'Lora', Georgia, serif;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7645;
    transition: color 0.2s ease;
  }

  .obs-arrow {
    font-size: 0.72rem;
    color: #6b7645;
    transition: transform 0.2s ease;
  }

  .obs-link:hover .obs-label {
    color: #96b885;
  }

  .obs-link:hover .obs-arrow {
    transform: translateX(3px);
  }
</style>