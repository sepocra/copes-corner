---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
  <nav class="site-nav" aria-label="Main">
    <h2 class="site-title">
      <a class="wordmark" href="/">{SITE_TITLE}</a>
    </h2>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
  </nav>
</header>

<style>
  .site-header {
    margin: 0;
    padding: 0;
    background: #1e1e1e;
    border-bottom: 2px solid #6b7645;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
    width: 720px;
    max-width: calc(100% - 2em);
    margin: 0 auto;
    box-sizing: border-box;
    padding: 0.65rem 1em;
  }

  .site-title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.2;
    /* Lora for the wordmark to match body serif */
    font-family: 'Lora', Georgia, serif;
  }

  .wordmark,
  .wordmark:visited {
    color: #e8e0d0;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .wordmark:hover {
    color: #f5f0e6;
  }

  .internal-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.15rem 0.25rem;
  }

  .internal-links :global(a) {
    display: inline-block;
    padding: 0.4em 0.65em;
    color: #7a9e68;
    text-decoration: none;
    /* Source Serif 4 for nav links */
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 0.85rem;
    font-weight: 300;
    letter-spacing: 0.06em;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.35em;
    transition: color 0.2s ease;
  }

  .internal-links :global(a:hover) {
    color: #96b885;
  }

  .internal-links :global(a.active) {
    color: #96b885;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: #96b885;
  }

  @media (max-width: 640px) {
    .site-nav {
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .internal-links {
      justify-content: center;
    }
  }
</style>