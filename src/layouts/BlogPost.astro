---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, subtitle, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description} mainClass="blog-post-main">
  <style is:global slot="head">
    main.blog-post-main {
      width: calc(100% - 2em);
      max-width: 100%;
      margin: 0;
    }
  </style>

  <article class="prose">

    <a class="back-link" href="/blog/">
      <span class="back-arrow" aria-hidden="true">&larr;</span>
      <span class="back-label">All observations</span>
    </a>

    <div class="title">
      <div class="date">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <div class="last-updated-on">
            Last updated on <FormattedDate date={updatedDate} />
          </div>
        )}
      </div>
      <h1>{title}</h1>
      {subtitle && (
        <p class="subtitle">{subtitle}</p>
      )}
      <hr />
    </div>

    <slot />

  </article>
</BaseLayout>

<style>
  .prose {
    width: 720px;
    max-width: calc(100% - 2em);
    margin: auto;
    padding: 2.5rem 1em 4rem;
  }

  /* ── Back link — matches "All observations" label style ── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    margin-bottom: 2.5rem;
  }

  .back-arrow {
    font-size: 0.72rem;
    color: #6b7645;
    transition: transform 0.2s ease;
  }

  .back-label {
    font-family: 'Lora', Georgia, serif;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7645;
    transition: color 0.2s ease;
  }

  .back-link:hover .back-label {
    color: #96b885;
  }

  .back-link:hover .back-arrow {
    transform: translateX(-3px);
  }

  /* ── Post title block ── */
  .title {
    margin-bottom: 1.5em;
    padding: 0.5em 0 1em;
    text-align: left;
    line-height: 1;
  }

  .title h1 {
    margin: 0 0 0.5em 0;
    font-size: 1.6rem;
    line-height: 1.25;
  }

  .subtitle {
    margin: 0.8em 0 1em 0;
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.5;
    color: #666;
    font-style: italic;
  }

  .date {
    margin-bottom: 0.6em;
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 300;
    font-size: 0.8rem;
    color: #888;
    letter-spacing: 0.02em;
  }

  .last-updated-on {
    font-style: italic;
  }

  @media (max-width: 720px) {
    .title {
      padding: 0.25em 0 0.75em;
    }

    .title h1 {
      font-size: clamp(1.2rem, 6vw, 1.6rem);
      margin: 0 0 0.5em 0;
    }

    .subtitle {
      font-size: clamp(0.95rem, 4vw, 1.05rem);
      margin: 0.6em 0 0.9em 0;
    }

    .prose {
      padding: 1.5rem 0.5em 3rem;
    }
  }
</style>
