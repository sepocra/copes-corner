---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type NavPost = {
	id: string;
	title: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: NavPost | null;
	nextPost?: NavPost | null;
};

const { title, description, pubDate, updatedDate, prevPost, nextPost } = Astro.props;
const hasPostNav = prevPost || nextPost;
---

<BaseLayout title={title} description={description}>

  <article class="prose">

    <a class="back-link" href="/blog/">
      <span class="back-arrow" aria-hidden="true">&larr;</span>
      <span class="back-label">All observations</span>
    </a>

    <div class="title">
      <div class="date">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <div class="last-updated-on">
            Last updated on <FormattedDate date={updatedDate} />
          </div>
        )}
      </div>
      <h1>{title}</h1>
      {description && (
        <p class="subtitle">{description}</p>
      )}
      <hr />
    </div>

    <slot />

    {hasPostNav && (
      <nav
        class:list={['post-nav', { 'post-nav--single': !prevPost || !nextPost }]}
        aria-label="More observations"
      >
        {prevPost && (
          <a class="post-nav-link post-nav-prev" href={`/blog/${prevPost.id}/`}>
            <span class="post-nav-label">
              <span class="post-nav-arrow" aria-hidden="true">&larr;</span>
              <span>Previous observation</span>
            </span>
            <span class="post-nav-title">{prevPost.title}</span>
          </a>
        )}
        {nextPost && (
          <a class="post-nav-link post-nav-next" href={`/blog/${nextPost.id}/`}>
            <span class="post-nav-label">
              <span>Next observation</span>
              <span class="post-nav-arrow" aria-hidden="true">&rarr;</span>
            </span>
            <span class="post-nav-title">{nextPost.title}</span>
          </a>
        )}
      </nav>
    )}

  </article>
</BaseLayout>

<style>
  .prose {
    width: 720px;
    max-width: 100%;
    margin: auto;
    /* No top padding — <main> from global.css already provides 3em */
    padding: 0 0 2rem;
  }

  /* ── Back link — matches "All observations" label style ── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    margin-bottom: 2.5rem;
  }

  .back-arrow {
    font-size: 0.72rem;
    color: #6b7645;
    transition: transform 0.2s ease;
  }

  .back-label {
    font-family: 'Lora', Georgia, serif;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7645;
    transition: color 0.2s ease;
  }

  .back-link:hover .back-label {
    color: #96b885;
  }

  .back-link:hover .back-arrow {
    transform: translateX(-3px);
  }

  /* ── Post title block ── */
  .title {
    margin-bottom: 1.5em;
    padding: 0.5em 0 1em;
    text-align: left;
    line-height: 1;
  }

  .title h1 {
    margin: 0 0 0.5em 0;
    font-size: 1.6rem;
    line-height: 1.25;
  }

  .subtitle {
    margin: 0.8em 0 1em 0;
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.5;
    color: #666;
    font-style: italic;
  }

  .date {
    margin-bottom: 0.6em;
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 300;
    font-size: 0.8rem;
    color: #888;
    letter-spacing: 0.02em;
  }

  .last-updated-on {
    font-style: italic;
  }

  /* ── Previous / next — matches blog index list styling ── */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-top: 3rem;
    border-top: 1px solid var(--content-border);
  }

  .post-nav--single {
    grid-template-columns: 1fr;
  }

  .post-nav-link {
    display: block;
    text-decoration: none;
    padding: 1.5rem 0;
    transition: color 0.2s ease;
  }

  .post-nav-prev {
    padding-right: 1.25rem;
  }

  .post-nav-next {
    padding-left: 1.25rem;
    text-align: right;
  }

  .post-nav--single .post-nav-next {
    padding-left: 0;
  }

  .post-nav--single .post-nav-prev:only-child {
    padding-right: 0;
  }

  .post-nav-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Lora', Georgia, serif;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7645;
    transition: color 0.2s ease;
  }

  .post-nav-next .post-nav-label {
    flex-direction: row-reverse;
  }

  .post-nav-arrow {
    font-size: 0.72rem;
    color: #6b7645;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .post-nav-title {
    display: block;
    margin: 0.5rem 0 0;
    font-family: 'Lora', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--content-heading, rgb(15, 18, 25));
    transition: color 0.2s ease;
  }

  .post-nav-link:hover .post-nav-label,
  .post-nav-link:hover .post-nav-arrow {
    color: #96b885;
  }

  .post-nav-link:hover .post-nav-title {
    color: var(--color-olive);
  }

  .post-nav-prev:hover .post-nav-arrow {
    transform: translateX(-3px);
  }

  .post-nav-next:hover .post-nav-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 720px) {
    .post-nav {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .post-nav-link {
      padding: 1rem 0;
    }

    .post-nav-next {
      padding-left: 0;
      text-align: left;
    }

    .post-nav-next .post-nav-label {
      flex-direction: row;
    }

    .post-nav-prev {
      padding-right: 0;
    }

    .post-nav-title {
      font-size: clamp(0.95rem, 4vw, 1.05rem);
    }

    .title {
      padding: 0.25em 0 0.75em;
    }

    .title h1 {
      font-size: clamp(1.2rem, 6vw, 1.6rem);
      margin: 0 0 0.5em 0;
    }

    .subtitle {
      font-size: clamp(0.95rem, 4vw, 1.05rem);
      margin: 0.6em 0 0.9em 0;
    }
  }

  @media (prefers-color-scheme: dark) {
    .subtitle {
      color: #c8c0b0;
    }
    .date {
      color: #a09890;
    }
  }
</style>