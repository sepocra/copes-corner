---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  lang?: string;
  /** Extra class on `<main>` for page-specific layout (use with `is:global` styles). */
  mainClass?: string;
}

const { title, description, image, lang = 'en', mainClass } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={image} />
    <!-- Source Serif 4 + Lora for header/footer typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-HTQ5WHMLZF"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-HTQ5WHMLZF');
</script>

  </head>
  <body class="site-root">
    <Header />
    <main class:list={['content-area', mainClass]}>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* ── Reset ── */
  *, *::before, *::after {
    box-sizing: border-box;
  }

  /* ── Light mode (default) ── */
  .content-area {
    background: #ffffff;
    color: #2d2d2d;
    min-height: 60vh;
    transition: background 0.3s, color 0.3s;
  }

  /* ── Dark mode: follows OS preference automatically ── */
  @media (prefers-color-scheme: dark) {
    .content-area {
      background: #1e1e1e;
      color: #d4cfc7;
    }

    /* Post titles */
    .content-area h1,
    .content-area h2,
    .content-area h3 {
      color: #7a9e68;
    }

    /* Body text */
    .content-area p,
    .content-area li {
      color: #b0a898;
    }

    /* Dividers */
    .content-area hr {
      border-color: rgba(255, 255, 255, 0.08);
    }

    /* Links within content */
    .content-area a {
      color: #7a9e68;
    }

    .content-area a:hover {
      color: #96b885;
    }

    /* Post meta (dates, tags) */
    .content-area .post-meta,
    .content-area time,
    .content-area .date {
      color: #666;
    }

    /* Excerpt / description text */
    .content-area .description,
    .content-area .excerpt {
      color: #777;
    }
  }
</style>
